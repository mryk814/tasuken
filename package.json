{
  "name": "tasuken-research-desk",
  "version": "0.1.0",
  "description": "研究開発職向けの長期スケジュール・タスク・メモ管理デスクトップアプリ",
  "author": "ootan",
  "private": true,
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev": "npm run desktop",
    "build": "vite build",
    "desktop": "npm run build && electron --disable-gpu --disable-gpu-compositing .",
    "smoke:desktop": "npm run build && electron --disable-gpu --disable-gpu-compositing . --smoke-test",
    "smoke:model": "electron --no-sandbox scripts/model-smoke.mjs",
    "package": "npm run build && electron-builder --win nsis --config.electronDist=node_modules/electron/dist"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "5.0.4",
    "electron": "^37.2.6",
    "electron-builder": "^26.15.3",
    "playwright": "^1.60.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "vite": "6.4.2"
  },
  "build": {
    "appId": "jp.personal.researchdesk",
    "productName": "Research Desk",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Research-Desk-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^12.10.1"
  }
}
