{
  "name": "tasken",
  "version": "0.1.18",
  "description": "研究開発職向けの長期スケジュール・タスク・メモ管理デスクトップアプリ",
  "author": "ootan",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev": "electron-vite dev",
    "test": "node --test tests/*.test.mjs",
    "typecheck": "tsc -b",
    "build": "electron-vite build",
    "desktop": "npm run build && electron --disable-gpu --disable-gpu-compositing .",
    "smoke:desktop": "npm run build && electron --disable-gpu --disable-gpu-compositing . --smoke-test",
    "smoke:model": "electron --no-sandbox scripts/model-smoke.mjs",
    "mcp": "set ELECTRON_RUN_AS_NODE=1&& electron scripts/mcp-server.mjs",
    "package": "npm run typecheck && npm run build && electron-builder --publish never --win nsis portable --config.electronDist=node_modules/electron/dist",
    "release:verify-version": "node scripts/verify-release-version.mjs",
    "release:check": "npm run release:verify-version && npm test && npm run package"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.9.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "^37.10.3",
    "electron-builder": "^26.15.5",
    "electron-vite": "^5.0.0",
    "playwright": "^1.61.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "6.4.3"
  },
  "build": {
    "appId": "jp.personal.tasken",
    "productName": "Tasken",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "resources/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "Tasken-Setup-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "Tasken-Portable-${version}-${arch}.${ext}"
    }
  },
  "dependencies": {
    "@codemirror/view": "^6.43.4",
    "@mdxeditor/editor": "^4.0.4",
    "@tabler/icons-react": "^3.44.0",
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^12.11.1",
    "katex": "^0.17.0",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-gfm-strikethrough": "^2.0.0",
    "mdast-util-gfm-table": "^2.0.0",
    "mdast-util-math": "^3.0.0",
    "mdast-util-to-string": "^4.0.0",
    "mermaid": "^11.16.0",
    "micromark-extension-gfm-strikethrough": "^2.1.0",
    "micromark-extension-gfm-table": "^2.1.1",
    "micromark-extension-math": "^3.1.0",
    "zustand": "^5.0.14"
  }
}
